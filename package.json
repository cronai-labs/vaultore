{
  "name": "vaultore",
  "version": "0.1.0",
  "private": true,
  "description": "A Markdown-native AI workflow engine for Obsidian",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cronai-ug/vaultore.git"
  },
  "author": "Tobias <tobias@cronai.de>",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "dev": "turbo run dev --filter=./packages/*",
    "test": "turbo run test --filter=./packages/*",
    "test:integration": "turbo run test:integration --filter=./packages/*",
    "test:canonical": "turbo run test:canonical --filter=./packages/*",
    "lint": "turbo run lint --filter=./packages/*",
    "typecheck": "turbo run typecheck --filter=./packages/*",
    "clean": "turbo run clean --filter=./packages/* && rm -rf node_modules",
    "format": "prettier --write .",
    "obsidian:dev": "turbo run dev --filter=@vaultore/obsidian",
    "obsidian:build": "turbo run build --filter=@vaultore/obsidian",
    "obsidian:package": "node ./scripts/package-obsidian.mjs",
    "core:build": "turbo run build --filter=@vaultore/core",
    "core:test": "turbo run test --filter=@vaultore/core"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.0"
  }
}
